{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "updoc",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["updoc", "--path", "${input:updoc_path}"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "deldoc",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["deldoc", "--path", "${input:deldoc_path}"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "chat",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["chat"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        },
        {
            "name": "qd --models",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "args": ["qd", "--models"],
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ],
    "inputs": [
        {
            "id": "updoc_path",
            "type": "promptString",
            "description": "Path to file or folder to ingest",
            "default": "data/in"
        },
        {
            "id": "deldoc_path",
            "type": "promptString",
            "description": "Path to file or folder to delete",
            "default": "data/in"
        }
    ]
}